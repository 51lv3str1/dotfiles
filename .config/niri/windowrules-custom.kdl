// Personal overrides (NOT managed by DMS).
// Included AFTER dms/windowrules.kdl in config.kdl so these win: niri applies
// matching window-rules in order and the last one takes precedence.

// Inactive windows are NOT dimmed (1.0) so they stay readable with many windows
// open. niri's opacity multiplies with the terminal's (Alacritty is at 0.90), so
// lowering it made inactive windows illegible. Focus is conveyed by the purple
// ring + glow, not by transparency. (DMS defaults this to 0.90.)
window-rule {
    match is-active=false
    opacity 1.0
}

// Neon glow: purple shadow on the active window ONLY (offset 0,0 = symmetric halo
// all around). Inactive windows have no shadow, so the glow reinforces which one
// has focus.
window-rule {
    match is-active=true
    shadow {
        on
        softness 28
        spread 4
        offset x=0 y=0
        color "#7355a677"
    }
}
