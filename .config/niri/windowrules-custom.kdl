// Overrides propios (NO gestionados por DMS).
// Se incluye DESPUÉS de dms/windowrules.kdl en config.kdl, así que estas reglas
// ganan: niri aplica las window-rules que coinciden en orden y la última pisa.

// Inactivas SIN oscurecer (1.0) para que se lean bien con muchas ventanas
// abiertas. La opacidad de niri se multiplica con la del terminal (Alacritty
// tiene 0.90), así que bajarla hacía ilegibles las inactivas. El foco lo marcan
// el anillo morado + el glow, no la transparencia. (DMS por defecto pone 0.90.)
window-rule {
    match is-active=false
    opacity 1.0
}

// Glow neón: sombra morada SOLO en la ventana activa (offset 0,0 = halo
// simétrico alrededor). Las inactivas no llevan sombra, así el resplandor
// refuerza cuál tiene el foco.
window-rule {
    match is-active=true
    shadow {
        on
        softness 40
        spread 8
        offset x=0 y=0
        color "#7355a6aa"
    }
}
