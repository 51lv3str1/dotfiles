// overview
include "overview.kdl"

// cursor
include "dms/cursor.kdl" //dms overrides

// debug
include "debug.kdl"

hotkey-overlay {
    skip-at-startup
}

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"
