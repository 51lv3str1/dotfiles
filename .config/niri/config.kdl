// notifications
include "notifications.kdl"

// environment
include "environment.kdl"

// spawn-at-startup
include "start.kdl"

// outputs
include "outputs.kdl"
include "dms/outputs.kdl" //dms overrides

// layer
include "layerrules.kdl"

// layout
include "layout.kdl"

// windowrules
include "windowrules.kdl"
include "dms/windowrules.kdl" //dms overrides

// inputs
include "gestures.kdl"
include "inputs.kdl"

// keybindings
include "binds.kdl"
include "dms/binds.kdl" //dms overrides

// animations
//include "animations/default/animations.kdl"
//include "animations/dissolve/animations.kdl"
include "animations/fade/animations.kdl"
//include "animations/glitch/animations.kdl"
//include "animations/pixelate/animations.kdl"
//include "animations/ripple/animations.kdl"
//include "animations/smoke/animations.kdl"
